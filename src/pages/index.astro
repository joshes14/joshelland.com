---
import BaseLayout from "../layouts/BaseLayout.astro";
import AnimatedHeading from "../components/AnimatedHeading";
import FadeIn from "../components/FadeIn";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter(p => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestPost = posts[0];
---

<BaseLayout title="Josh — Creative Developer" description="Welcome to Josh's corner of the internet. Projects, thoughts, and life through a creative lens.">
  <section class="relative min-h-[86vh] flex items-center overflow-hidden" id="hero">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 right-0 w-80 h-80 bg-vintage-clay/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-8 -left-12 w-72 h-72 bg-tennis-yellow/20 rounded-full blur-3xl"></div>
      <div class="court-lines"></div>
    </div>

    <div class="section-shell relative z-10 w-full pt-16 md:pt-8">
      <div class="max-w-3xl">
        <FadeIn client:load delay={0}>
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium text-muted-slate uppercase tracking-[0.16em] mb-8 glass-panel">
            <span class="w-1.5 h-1.5 rounded-full bg-tennis-yellow animate-pulse"></span>
            <span>Grand Slam energy for digital craft</span>
          </div>
        </FadeIn>

        <AnimatedHeading
          client:load
          text="Soft focus. Sharp execution."
          className="text-5xl sm:text-6xl md:text-8xl font-display font-semibold tracking-tight text-vintage-green mb-6"
          delay={0.1}
        />

        <FadeIn client:load delay={0.45}>
          <p class="text-lg md:text-2xl text-muted-slate leading-relaxed max-w-2xl mb-10 font-body font-normal">
            I build digital products with a clean rhythm, document the process in writing, and share visual and sonic inspiration that keeps the work moving.
          </p>
        </FadeIn>

        <FadeIn client:load delay={0.6}>
          <div class="flex flex-wrap gap-3 mt-6">
            <a href="/about" id="cta-about" class="focus-ring cta-primary inline-flex items-center justify-center px-7 py-3 rounded-xl font-semibold transition-all duration-300">
              Get to know me
            </a>
            <a href="/music" id="cta-music" class="focus-ring cta-secondary inline-flex items-center justify-center px-7 py-3 rounded-xl font-semibold transition-all duration-300">
              Visit music room
            </a>
          </div>
        </FadeIn>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24" id="highlights">
    <div class="section-shell">
      <FadeIn client:load>
        <div class="mb-12 md:mb-14">
          <h2 class="text-3xl md:text-5xl font-display font-semibold text-vintage-green mb-3">
            Explore by mood
          </h2>
          <p class="text-muted-slate text-lg max-w-xl">
            Four ways to navigate the same creative thread.
          </p>
        </div>
      </FadeIn>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <FadeIn client:load delay={0.06}>
          <a href="/blog" class="surface-panel rounded-2xl p-6 h-full flex flex-col group hover:border-vintage-clay/45 transition-all duration-300 cursor-pointer" id="highlight-blog">
            <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">Writing</h3>
            <p class="text-muted-slate text-sm leading-relaxed mb-8 flex-grow">Build notes, architecture choices, and practical lessons.</p>
            <span class="text-xs uppercase tracking-[0.2em] font-medium text-vintage-green group-hover:text-vintage-clay transition-colors">Read blog</span>
          </a>
        </FadeIn>

        <FadeIn client:load delay={0.12}>
          <a href="/gallery" class="surface-panel rounded-2xl p-6 h-full flex flex-col group hover:border-vintage-clay/45 transition-all duration-300 cursor-pointer" id="highlight-gallery">
            <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">Gallery</h3>
            <p class="text-muted-slate text-sm leading-relaxed mb-8 flex-grow">Photos, concepts, and snapshots from ongoing experiments.</p>
            <span class="text-xs uppercase tracking-[0.2em] font-medium text-vintage-green group-hover:text-vintage-clay transition-colors">View gallery</span>
          </a>
        </FadeIn>

        <FadeIn client:load delay={0.18}>
          <a href="/about" class="surface-panel rounded-2xl p-6 h-full flex flex-col group hover:border-vintage-clay/45 transition-all duration-300 cursor-pointer" id="highlight-about">
            <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">About</h3>
            <p class="text-muted-slate text-sm leading-relaxed mb-8 flex-grow">Background, values, and how I approach craft and systems.</p>
            <span class="text-xs uppercase tracking-[0.2em] font-medium text-vintage-green group-hover:text-vintage-clay transition-colors">Meet Josh</span>
          </a>
        </FadeIn>

        <FadeIn client:load delay={0.24}>
          <a href="/music" class="surface-panel rounded-2xl p-6 h-full flex flex-col group hover:border-vintage-clay/45 transition-all duration-300 cursor-pointer" id="highlight-music">
            <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">Music</h3>
            <p class="text-muted-slate text-sm leading-relaxed mb-8 flex-grow">A rotating set of tracks and playlists that frame each project season.</p>
            <span class="text-xs uppercase tracking-[0.2em] font-medium text-vintage-green group-hover:text-vintage-clay transition-colors">Open music page</span>
          </a>
        </FadeIn>
      </div>
    </div>
  </section>

  <section class="pb-10 md:pb-16" id="recent-posts">
    <div class="section-shell">
      <FadeIn client:load>
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 gap-4">
          <div class="max-w-xl">
            <h2 class="text-3xl md:text-4xl font-display font-semibold text-vintage-green mb-2">Latest writing</h2>
            <p class="text-muted-slate text-base">One recent post to start with.</p>
          </div>
          <a href="/blog" class="text-sm font-medium uppercase tracking-[0.2em] text-vintage-green hover:text-vintage-clay transition-colors">All articles</a>
        </div>
      </FadeIn>

      <FadeIn client:load delay={0.1}>
        {latestPost ? (
          <a href={`/blog/${latestPost.id}`} class="block group cursor-pointer">
            <article class="surface-panel rounded-2xl p-7 md:p-9 group-hover:border-vintage-clay/45 transition-all duration-300">
              <div class="flex items-center gap-4 mb-5">
                {latestPost.data.tags && latestPost.data.tags.length > 0 && (
                  <span class="text-xs font-semibold px-2 py-1 bg-white/80 border border-warm-border text-vintage-green uppercase tracking-widest rounded-md">{latestPost.data.tags[0]}</span>
                )}
                <span class="text-xs text-muted-slate font-medium">
                  {latestPost.data.date.toLocaleDateString("en-US", { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
              </div>
              <h3 class="font-display text-2xl md:text-3xl font-semibold text-vintage-green mb-3 group-hover:text-vintage-clay transition-colors duration-300">
                {latestPost.data.title}
              </h3>
              <p class="text-muted-slate leading-relaxed max-w-3xl text-lg line-clamp-2">
                {latestPost.data.description}
              </p>
            </article>
          </a>
        ) : (
          <div class="p-12 border border-dashed border-warm-border text-center text-muted-slate rounded-2xl surface-panel">
            <p>New stories arriving soon.</p>
          </div>
        )}
      </FadeIn>
    </div>
  </section>
</BaseLayout>
