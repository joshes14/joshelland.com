---
import BaseLayout from "../../layouts/BaseLayout.astro";
import GalleryCard from "../../components/GalleryCard.astro";
import FadeIn from "../../components/FadeIn";
import { getCollection } from "astro:content";

const items = (await getCollection("gallery"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = ["all", "photography", "design", "life", "projects"];
---

<BaseLayout title="Gallery — Josh" description="Photos, designs, and visual stories from Josh's life.">
  <section class="relative overflow-hidden pt-32 pb-20 border-b border-border" id="gallery-hero">
    <div class="max-w-6xl mx-auto px-6 relative z-10 w-full">
      <FadeIn client:load>
        <span class="text-sm font-medium uppercase tracking-widest text-text-muted mb-4 block">Visuals</span>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-display font-semibold text-primary mb-6">
          The Gallery
        </h1>
        <p class="text-xl md:text-2xl text-text-muted max-w-2xl font-body font-light">
          A collected archive of photography, visual design, and life snapshots.
        </p>
      </FadeIn>
    </div>
  </section>

  <!-- Filter tabs -->
  <section class="py-24 bg-[#F2EAE0]" id="gallery-grid">
    <div class="max-w-6xl mx-auto px-6">
      <FadeIn client:load>
        <div class="flex flex-wrap gap-3 mb-16" id="gallery-filters">
          {categories.map((cat) => (
            <button
              class="gallery-filter px-6 py-2 border border-border bg-[#F2EAE0] text-primary text-xs uppercase tracking-widest font-medium transition-colors duration-300 hover:bg-accent/40"
              data-category={cat}
            >
              {cat}
            </button>
          ))}
        </div>
      </FadeIn>

      {items.length === 0 ? (
        <FadeIn client:load>
          <div class="text-center py-32 border border-border">
            <div class="mb-6 opacity-30">
              <svg class="w-12 h-12 text-primary mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
            </div>
            <h2 class="font-display text-2xl font-semibold text-primary mb-2">Gallery is empty</h2>
            <p class="text-text-muted">Visual stories coming soon.</p>
          </div>
        </FadeIn>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8" id="gallery-items">
          {items.map((item, i) => (
            <FadeIn client:load delay={i * 0.05}>
              <div class="gallery-item" data-category={item.data.category}>
                <GalleryCard
                  title={item.data.title}
                  cover={item.data.cover}
                  category={item.data.category}
                  description={item.data.description}
                />
              </div>
            </FadeIn>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<!-- Lightbox Modal -->
<dialog id="gallery-lightbox" class="fixed inset-0 m-0 p-0 w-full h-full max-w-full max-h-full bg-black/90 z-50 backdrop-blur-sm hidden flex-col items-center justify-center">
  <button id="lightbox-close" class="absolute top-6 right-6 text-white hover:text-white/70 transition-colors z-50 shrink-0">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <div class="relative max-w-7xl max-h-[90vh] w-full p-4 md:p-12 flex flex-col items-center justify-center">
    <img id="lightbox-img" src="" alt="Gallery visual" class="max-w-full max-h-[85vh] object-contain shadow-2xl transition-opacity duration-300 opacity-0" />
    <p id="lightbox-title" class="text-white mt-4 font-display text-lg tracking-wide"></p>
  </div>
</dialog>

<script>
  // Gallery filtering
  const filters = document.querySelectorAll<HTMLButtonElement>(".gallery-filter");
  const items = document.querySelectorAll<HTMLElement>(".gallery-item");

  // Set "all" as active by default
  const activateFilter = (f: HTMLElement) => {
    f.style.backgroundColor = "var(--color-primary)";
    f.style.color = "var(--color-surface)";
    f.style.borderColor = "var(--color-primary)";
  };

  const deactivateFilter = (f: HTMLElement) => {
    f.style.backgroundColor = "var(--color-bg)";
    f.style.color = "var(--color-primary)";
    f.style.borderColor = "var(--color-border)";
  };

  if (filters[0]) activateFilter(filters[0]);

  filters.forEach((filter) => {
    filter.addEventListener("click", () => {
      const category = filter.dataset.category;

      // Update active filter styles
      filters.forEach((f) => deactivateFilter(f));
      activateFilter(filter);

      // Filter items
      items.forEach((item) => {
        if (category === "all" || item.dataset.category === category) {
          item.style.display = "";
          item.style.opacity = "0";
          item.style.transform = "scale(0.98)";
          requestAnimationFrame(() => {
            item.style.transition = "opacity 0.4s ease, transform 0.4s ease";
            item.style.opacity = "1";
            item.style.transform = "scale(1)";
          });
        } else {
          item.style.opacity = "0";
          item.style.transform = "scale(0.98)";
          setTimeout(() => {
            item.style.display = "none";
          }, 300);
        }
      });
    });
  });

  // Lightbox functionality
  const lightbox = document.getElementById("gallery-lightbox") as HTMLDialogElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lightboxTitle = document.getElementById("lightbox-title");
  const closeBtn = document.getElementById("lightbox-close");
  const galleryCards = document.querySelectorAll<HTMLElement>(".group[data-src]");

  // Open modal
  galleryCards.forEach((card) => {
    card.addEventListener("click", () => {
      const src = card.getAttribute("data-src");
      const title = card.getAttribute("data-title");
      
      if (src) {
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        // Use setAttribute so we trigger load
        lightboxImg.src = src;
        if (lightboxTitle) lightboxTitle.textContent = title || "";
        
        // Show after loaded to avoid flicker
        lightboxImg.onload = () => {
          lightboxImg.style.opacity = "1";
        };
        // Remove document scroll
        document.body.style.overflow = "hidden";
      }
    });
  });

  // Close modal
  const closeModal = () => {
    lightbox.classList.add("hidden");
    lightbox.classList.remove("flex");
    lightboxImg.style.opacity = "0";
    lightboxImg.src = "";
    document.body.style.overflow = "";
  };

  closeBtn?.addEventListener("click", closeModal);
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox || e.target !== lightboxImg) {
      closeModal();
    }
  });

  // Escape key to close
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !lightbox.classList.contains("hidden")) {
      closeModal();
    }
  });
</script>
