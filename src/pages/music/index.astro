---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FadeIn from "../../components/FadeIn";

const featuredSets = [
  {
    title: "Pre-Ship Focus",
    mood: "Clean tempo for long implementation sessions.",
    tracks: "10 tracks",
  },
  {
    title: "Late Night Refactor",
    mood: "Low-light electronic and modern jazz texture.",
    tracks: "14 tracks",
  },
  {
    title: "Weekend Concept Sprint",
    mood: "Warm energy for sketching and prototyping.",
    tracks: "12 tracks",
  },
];

const nowPlaying = [
  "Tourist - Apollo",
  "Rival Consoles - Recovery",
  "Nils Frahm - Says",
  "Bicep - Glue",
  "Jamie xx - Gosh",
];
---

<BaseLayout title="Music — Josh" description="A soft, focused soundtrack layer behind my design and engineering process.">
  <section class="relative overflow-hidden pt-28 pb-14" id="music-hero">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-20 right-12 w-72 h-72 bg-vintage-clay/12 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-72 h-72 bg-tennis-yellow/20 rounded-full blur-3xl"></div>
    </div>

    <div class="section-shell relative z-10">
      <FadeIn client:load>
        <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-xs font-medium text-muted-slate uppercase tracking-[0.16em] mb-6 glass-panel">
          Soundtrack archive
        </span>
      </FadeIn>

      <FadeIn client:load delay={0.08}>
        <h1 class="text-4xl sm:text-5xl md:text-7xl font-display font-semibold text-vintage-green mb-4 max-w-3xl">
          Music that keeps the work in rhythm.
        </h1>
      </FadeIn>

      <FadeIn client:load delay={0.15}>
        <p class="text-lg md:text-2xl text-muted-slate max-w-2xl leading-relaxed">
          This is the listening layer behind my writing and build cycles. Nothing loud, mostly intentional pacing.
        </p>
      </FadeIn>
    </div>
  </section>

  <section class="pb-8 md:pb-12" id="music-featured-sets">
    <div class="section-shell">
      <FadeIn client:load>
        <h2 class="text-2xl md:text-4xl font-display font-semibold text-vintage-green mb-8">Featured sets</h2>
      </FadeIn>

      <div class="grid md:grid-cols-3 gap-5">
        {featuredSets.map((set, i) => (
          <FadeIn client:load delay={0.08 + i * 0.06}>
            <article class="surface-panel rounded-2xl p-6 h-full">
              <p class="text-xs uppercase tracking-[0.2em] text-vintage-clay font-semibold mb-4">{set.tracks}</p>
              <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">{set.title}</h3>
              <p class="text-muted-slate leading-relaxed text-sm">{set.mood}</p>
            </article>
          </FadeIn>
        ))}
      </div>
    </div>
  </section>

  <section class="pb-12 md:pb-16" id="music-now-playing">
    <div class="section-shell">
      <FadeIn client:load>
        <div class="glass-panel rounded-3xl p-7 md:p-10">
          <h2 class="text-2xl md:text-4xl font-display font-semibold text-vintage-green mb-6">Now spinning</h2>
          <ul class="grid sm:grid-cols-2 gap-3">
            {nowPlaying.map((track) => (
              <li class="surface-panel rounded-xl px-4 py-3 text-sm text-vintage-green font-medium">{track}</li>
            ))}
          </ul>
        </div>
      </FadeIn>
    </div>
  </section>
</BaseLayout>
