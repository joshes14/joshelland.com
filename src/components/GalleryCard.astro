---
interface Props {
  title: string;
  cover: string;
  category: string;
  description?: string;
}

const { title, cover, category, description } = Astro.props;
---

<div class="group cursor-pointer relative block overflow-hidden aspect-square" data-src={cover} data-title={title}>
  <img
    src={cover}
    alt={title}
    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
    loading="lazy"
  />
  
  <!-- Overlay info on hover (Instagram inspired) -->
  <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center p-6 text-center">
    <h3 class="font-display text-white text-xl md:text-2xl font-semibold mb-2">{title}</h3>
    <span class="text-xs uppercase tracking-widest font-semibold text-white/90">
      {category}
    </span>
    {description && (
      <p class="text-white/80 text-sm mt-4 line-clamp-2 md:line-clamp-3 font-body max-w-xs">{description}</p>
    )}
  </div>
</div>
