---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  cover?: string;
  tags?: string[];
}

const { title, description, date, slug, cover, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="group block" id={`blog-card-${slug}`}>
  <article class="flex flex-col md:flex-row gap-8 items-start group-hover:opacity-80 transition-opacity duration-300">
    {cover && (
      <div class="w-full md:w-1/3 aspect-[4/3] overflow-hidden flex-shrink-0">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover transition-all duration-700"
          loading="lazy"
        />
      </div>
    )}
    
    <div class="flex-grow">
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <time class="text-xs uppercase tracking-widest font-medium text-muted-slate">{formattedDate}</time>
        {tags.length > 0 && (
          <div class="flex gap-2">
            {tags.slice(0, 3).map((tag) => (
              <span class="text-xs font-semibold px-2 py-1 bg-tennis-yellow/40 text-vintage-green tracking-widest uppercase">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
      
      <h3 class="font-display text-2xl md:text-3xl font-semibold text-vintage-green mb-4 group-hover:text-vintage-clay group-hover:underline underline-offset-4 decoration-1 transition-all">
        {title}
      </h3>
      
      <p class="text-muted-slate text-lg leading-relaxed mb-6 font-body font-light">
        {description}
      </p>
      
      <div class="inline-flex items-center gap-2 text-sm uppercase tracking-widest font-semibold text-vintage-green">
        Read Article
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </article>
</a>
