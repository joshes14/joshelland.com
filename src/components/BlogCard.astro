---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  cover?: string;
  tags?: string[];
}

const { title, description, date, slug, cover, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<a href={`/blog/${slug}`} class="group block" id={`blog-card-${slug}`}>
  <article class="bg-white rounded-2xl overflow-hidden border border-border-light shadow-sm hover:shadow-xl hover:shadow-lavender/10 transition-all duration-500 hover:-translate-y-1">
    {cover && (
      <div class="aspect-[16/9] overflow-hidden">
        <img
          src={cover}
          alt={title}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
    )}
    
    <div class="p-6">
      <div class="flex items-center gap-3 mb-3">
        <time class="text-xs font-medium text-ink-muted">{formattedDate}</time>
        {tags.length > 0 && (
          <div class="flex gap-1.5">
            {tags.slice(0, 2).map((tag) => (
              <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-lavender/10 text-lavender">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
      
      <h3 class="font-display text-lg font-semibold text-ink mb-2 group-hover:text-lavender transition-colors duration-300">
        {title}
      </h3>
      
      <p class="text-ink-muted text-sm leading-relaxed line-clamp-2">
        {description}
      </p>
      
      <div class="mt-4 flex items-center gap-2 text-sm font-medium text-lavender">
        Read more
        <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </div>
    </div>
  </article>
</a>
