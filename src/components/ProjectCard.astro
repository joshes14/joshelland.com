---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  link?: string;
}

const { title, description, tags = [], link = "#" } = Astro.props;
---

<a href={link} class="group block h-full flex flex-col" id={`project-${title.toLowerCase().replace(/\s+/g, '-')}`}>
  <div class="surface-panel rounded-2xl p-8 group-hover:border-vintage-clay/40 group-hover:shadow-lg transition-all duration-300 h-full flex flex-col">
    <div class="w-12 h-1 bg-vintage-clay/40 mb-6 transition-all duration-500 group-hover:w-full group-hover:bg-vintage-clay"></div>
    
    <h3 class="font-display text-2xl font-semibold text-vintage-green mb-3">
      {title}
    </h3>
    
    <p class="text-muted-slate text-base leading-relaxed mb-6 font-body font-light flex-grow">
      {description}
    </p>
    
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6 mt-auto">
        {tags.map((tag) => (
          <span class="text-xs font-semibold px-2 py-1 bg-white/80 border border-warm-border text-vintage-green uppercase tracking-widest rounded-md">
            {tag}
          </span>
        ))}
      </div>
    )}
    
    <div class="mt-auto flex items-center gap-2 text-sm uppercase tracking-widest font-semibold text-vintage-green opacity-0 group-hover:opacity-100 group-hover:text-vintage-clay transition-all duration-300">
      View Project
      <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </div>
  </div>
</a>
