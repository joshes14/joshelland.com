---
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Blog", href: "/blog" },
  { label: "Gallery", href: "/gallery" },
];
---

<nav id="main-nav" transition:persist="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 animate-slide-down">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" id="nav-logo" class="font-display text-2xl font-bold tracking-tight group text-vintage-green">
      <span>Josh</span>
      <span class="inline-block w-1.5 h-1.5 rounded-full bg-vintage-green ml-0.5 mb-1 group-hover:scale-125 transition-transform duration-300"></span>
    </a>

    <!-- Desktop Links -->
    <div class="hidden md:flex items-center gap-6" id="nav-links-desktop">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "text-sm font-medium transition-colors duration-200",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "text-vintage-green"
              : "text-muted-slate hover:text-vintage-green",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex flex-col gap-1.5 p-2 rounded-md hover:bg-tennis-yellow/40 transition-colors"
      aria-label="Toggle menu"
    >
      <span class="block w-5 h-0.5 bg-vintage-green rounded-full transition-all duration-300" id="burger-1"></span>
      <span class="block w-5 h-0.5 bg-vintage-green rounded-full transition-all duration-300" id="burger-2"></span>
      <span class="block w-3.5 h-0.5 bg-vintage-green rounded-full transition-all duration-300 ml-auto" id="burger-3"></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="md:hidden hidden absolute top-full left-0 right-0 bg-cream-bg/95 backdrop-blur-xl border-b border-warm-border shadow-sm py-4"
  >
    <div class="max-w-6xl mx-auto px-6 flex flex-col gap-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "px-4 py-3 rounded-lg text-base font-medium transition-colors duration-200",
            currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href))
              ? "bg-tennis-yellow/40 text-vintage-green"
              : "text-muted-slate hover:text-vintage-green hover:bg-tennis-yellow/40",
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  const burger1 = document.getElementById("burger-1");
  const burger2 = document.getElementById("burger-2");
  const burger3 = document.getElementById("burger-3");

  let isOpen = false;

  btn?.addEventListener("click", () => {
    isOpen = !isOpen;
    menu?.classList.toggle("hidden");

    if (isOpen) {
      burger1!.style.transform = "rotate(45deg) translate(3px, 3px)";
      burger2!.style.opacity = "0";
      burger3!.style.transform = "rotate(-45deg) translate(3px, -3px)";
      burger3!.style.width = "1.25rem";
    } else {
      burger1!.style.transform = "";
      burger2!.style.opacity = "";
      burger3!.style.transform = "";
      burger3!.style.width = "";
    }
  });

  // Navbar scroll effect
  const nav = document.getElementById("main-nav");

  window.addEventListener("scroll", () => {
    if (window.scrollY > 50) {
      nav?.classList.add("bg-cream-bg/90", "backdrop-blur-xl", "border-b", "border-warm-border", "shadow-sm");
    } else {
      nav?.classList.remove("bg-cream-bg/90", "backdrop-blur-xl", "border-b", "border-warm-border", "shadow-sm");
    }
  });

  // Handle active link updates for seamless navigation
  document.addEventListener('astro:page-load', () => {
    const currentPath = window.location.pathname;
    const desktopLinks = document.querySelectorAll('#nav-links-desktop a');
    const mobileLinks = document.querySelectorAll('#mobile-menu a');
    
    const updateLinks = (links: NodeListOf<HTMLAnchorElement>, isMobile: boolean) => {
      links.forEach(link => {
        const href = link.getAttribute('href');
        if (!href) return;
        
        const isActive = currentPath === href || (href !== '/' && currentPath.startsWith(href));
        
        if (isActive) {
          if (isMobile) {
            link.classList.add('bg-tennis-yellow/40', 'text-vintage-green');
            link.classList.remove('text-muted-slate', 'hover:text-vintage-green', 'hover:bg-tennis-yellow/40');
          } else {
            link.classList.add('text-vintage-green');
            link.classList.remove('text-muted-slate', 'hover:text-vintage-green');
          }
        } else {
          if (isMobile) {
            link.classList.remove('bg-tennis-yellow/40', 'text-vintage-green');
            link.classList.add('text-muted-slate', 'hover:text-vintage-green', 'hover:bg-tennis-yellow/40');
          } else {
            link.classList.remove('text-vintage-green');
            link.classList.add('text-muted-slate', 'hover:text-vintage-green');
          }
        }
      });
    };
    
    updateLinks(desktopLinks as NodeListOf<HTMLAnchorElement>, false);
    updateLinks(mobileLinks as NodeListOf<HTMLAnchorElement>, true);

    // Also close mobile menu on page turn if it was left open
    if (isOpen && btn && menu) {
      isOpen = false;
      menu.classList.add("hidden");
      if (burger1 && burger2 && burger3) {
        burger1.style.transform = "";
        burger2.style.opacity = "";
        burger3.style.transform = "";
        burger3.style.width = "";
      }
    }
  });
</script>
